default:
    @just --list

# Run all checks
check: lint typecheck test

# Run ruff linter
lint:
    uv run ruff check .

# Run ruff formatter check (without fixes)
format-check:
    uv run ruff format --check .

# Format code with ruff (applies fixes)
format:
    uv run ruff format .
    uv run ruff check --fix .

# Run ty type checker
typecheck:
    uv run ty check

# Install prek git hooks
prek-install:
    uvx prek install
    
# Run all prek hooks
prek:
    uvx prek run --all-files

# Run tests
test *args:
    uv run pytest {{ '{{ args }}' }}

# Run tests with coverage
test-cov:
    uv run pytest --cov=src/{{ module_name }} --cov-report=term-missing

# Install dependencies and prek hooks
install:
    uv sync
    uvx prek install
{%- if is_ml_project %}
{%- if add_autoresearch %}

# Run the autoresearch loop
autoresearch config="autoresearch/configs/default_config.yaml":
    claude "follow autoresearch/program.md using {{ '{{config}}' }}"
{%- endif %}

# Train a model
train config *args:
    uv run scripts/train.py --config {{ '{{config}}' }} {{ '{{args}}' }}

# Evaluate a model
evaluate config model_path *args:
    uv run scripts/evaluate.py --config {{ '{{config}}' }} --model-path {{ '{{model_path}}' }} {{ '{{args}}' }}

# Run inference
predict config model_path *args:
    uv run scripts/predict.py --config {{ '{{config}}' }} --model-path {{ '{{model_path}}' }} {{ '{{args}}' }}
{%- endif %}
