editable_files:
  - "src/{{ module_name }}/models.py"
  - "configs/default_config.yaml"

metric:
  name: accuracy
  direction: maximize    # maximize or minimize

iterations: 10           # max iterations, or "unlimited"

time_budget_minutes:     # optional: kill runs exceeding this (null = no limit)

tree_search:
  max_branches: 3        # max children per node before pruning
  priority: "metric"     # "metric" = best first, "diversity" = explore different paths
  stuck_threshold: 5    # revert after this many consecutive failures on a branch

scripts:
  train: "uv run scripts/train.py --config configs/default_config.yaml --output-dir outputs/autoresearch"
  evaluate: "uv run scripts/evaluate.py --config configs/default_config.yaml --model-path outputs/autoresearch/best_model.pth --output-dir outputs/autoresearch/evaluation"
