[project]
name = "{{ project_name | to_slugify }}"
description = "{{ project_description }}"
authors = [{name = "{{ author_fullname }}", email = "{{ author_email }}"}]
version = "0.1.0"
readme = "README.md"
license = "{{ license }}"
requires-python = ">={{ python_version }}"
dependencies = [
    {%- if setup_logging %}
    "colorama>=0.4.6",
    {%- endif %}
    {%- if setup_settings or is_ml_project %}
    "pydantic>=2.11.3",
    "pydantic-settings>=2.9.0",
    {%- endif %}
    {%- if is_ml_project %}
    "pyyaml>=6.0",
    "numpy>=1.24.0",
    {%- if ml_framework == "pytorch" %}
    "torch>=2.0.0",
    "torchvision>=0.15.0",
    {%- elif ml_framework == "tensorflow" %}
    "tensorflow>=2.12.0",
    {%- elif ml_framework == "agnostic" %}
    "torch>=2.0.0",
    "torchvision>=0.15.0",
    {%- endif %}
    {%- if experiment_tracker == "wandb" %}
    "wandb>=0.15.0",
    {%- elif experiment_tracker == "mlflow" %}
    "mlflow>=2.0.0",
    {%- endif %}
    {%- endif %}
]

[dependency-groups]
dev = [
    "ruff>=0.4",
    "pytest>=8.2",
    "pytest-cov>=5.0",
    "pytest-randomly>=3.15",
    "pytest-xdist>=3.6",
    "ty>=0.0.14",
    "prek>=0.3.3",
    {%- if is_ml_project %}
    "scikit-learn>=1.3.0",
    "matplotlib>=3.7.0",
    "seaborn>=0.12.0",
    "pandas>=2.0.0",
    {%- endif %}
]

[tool.uv]
default-groups = ["dev"]

[tool.ruff]
line-length = 100

[tool.ruff.lint]
select = [
    "F",   # pyflakes
    "W",   # pycodestyle
    "E",   # pycodestyle
    "I",   # isort
    "UP",  # pyupgrade
]

ignore = [
    "E501",  # line-too-long
    "T201",  # print statement
]

[tool.ruff.format]
docstring-code-format = true

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ module_name }}"]
{%- if is_ml_project %}

[project.scripts]
{{ module_name }}-ml = "{{ module_name }}.ml.cli:main"
{%- endif %}
