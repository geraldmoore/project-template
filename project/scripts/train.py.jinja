def _create_optimizer(model, config: ExperimentConfig):
    """Create optimiser based on configuration."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch.optim as optim

    opt_config = config.training.optimizer
    if opt_config.name == "adam":
        return optim.Adam(model.parameters(), lr=opt_config.learning_rate, weight_decay=opt_config.weight_decay)
    elif opt_config.name == "sgd":
        return optim.SGD(model.parameters(), lr=opt_config.learning_rate, momentum=opt_config.momentum or 0.0, weight_decay=opt_config.weight_decay)
    else:
        return optim.Adam(model.parameters(), lr=opt_config.learning_rate)
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    import tensorflow as tf

    opt_config = config.training.optimizer
    if opt_config.name == "adam":
        return tf.keras.optimizers.Adam(learning_rate=opt_config.learning_rate, weight_decay=opt_config.weight_decay)
    elif opt_config.name == "sgd":
        return tf.keras.optimizers.SGD(learning_rate=opt_config.learning_rate, momentum=opt_config.momentum or 0.0)
    else:
        return tf.keras.optimizers.Adam(learning_rate=opt_config.learning_rate)
    {%- endif %}


def _create_criterion(config: ExperimentConfig):
    """Create loss function based on configuration."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch.nn as nn

    loss_config = config.training.loss
    if loss_config.name == "cross_entropy":
        return nn.CrossEntropyLoss()
    elif loss_config.name == "mse":
        return nn.MSELoss()
    elif loss_config.name == "bce":
        return nn.BCELoss()
    else:
        return nn.CrossEntropyLoss()
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    import tensorflow as tf

    loss_config = config.training.loss
    if loss_config.name == "cross_entropy":
        return tf.keras.losses.SparseCategoricalCrossentropy()
    elif loss_config.name == "mse":
        return tf.keras.losses.MeanSquaredError()
    else:
        return tf.keras.losses.SparseCategoricalCrossentropy()
    {%- endif %}


def _create_scheduler(optimizer, config: ExperimentConfig):
    """Create learning rate scheduler."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch.optim.lr_scheduler as lr_scheduler

    if config.training.scheduler_type == "reduce_on_plateau":
        return lr_scheduler.ReduceLROnPlateau(
            optimizer, mode="min", factor=0.1, patience=config.training.scheduler_patience
        )
    elif config.training.scheduler_type == "cosine":
        return lr_scheduler.CosineAnnealingLR(optimizer, T_max=config.training.num_epochs)
    else:
        return lr_scheduler.ReduceLROnPlateau(optimizer, mode="min")
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    import tensorflow as tf

    if config.training.scheduler_type == "reduce_on_plateau":
        return tf.keras.callbacks.ReduceLROnPlateau(
            monitor="val_loss", factor=0.1, patience=config.training.scheduler_patience
        )
    else:
        return tf.keras.experimental.CosineDecay(
            initial_learning_rate=config.training.optimizer.learning_rate,
            decay_steps=config.training.num_epochs,
        )
    {%- endif %}


def _train_one_epoch(model, dataloader, optimizer, criterion, epoch: int, config: ExperimentConfig) -> float:
    """Train for one epoch."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch

    model.train()
    total_loss = 0.0
    num_batches = 0

    for batch_idx, (inputs, targets) in enumerate(dataloader):
        # Move to device
        device = torch.device(config.device if torch.cuda.is_available() else "cpu")
        inputs, targets = inputs.to(device), targets.to(device)

        # Forward pass
        optimizer.zero_grad()
        outputs = model(inputs)
        loss = criterion(outputs, targets)

        # Backward pass
        loss.backward()

        # Gradient clipping
        if config.training.gradient_clip_value:
            torch.nn.utils.clip_grad_norm_(model.parameters(), config.training.gradient_clip_value)

        optimizer.step()

        total_loss += loss.item()
        num_batches += 1

        # Log batch metrics
        if (batch_idx + 1) % config.training.log_interval == 0:
            logger.info(f"Epoch {epoch + 1}, Batch {batch_idx + 1}: loss={loss.item():.4f}")

    return total_loss / num_batches
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    # TensorFlow implementation
    model.compile(optimizer=optimizer, loss=criterion)
    history = model.fit(dataloader, epochs=1, verbose=1)
    return history.history["loss"][0]
    {%- endif %}


def _evaluate_model(model, dataloader, criterion, config: ExperimentConfig) -> tuple[float, dict]:
    """Evaluate model on validation set."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch

    model.eval()
    total_loss = 0.0
    num_batches = 0
    metrics = {}

    with torch.no_grad():
        for inputs, targets in dataloader:
            device = torch.device(config.device if torch.cuda.is_available() else "cpu")
            inputs, targets = inputs.to(device), targets.to(device)

            outputs = model(inputs)
            loss = criterion(outputs, targets)

            total_loss += loss.item()
            num_batches += 1

    # Calculate additional metrics
    avg_loss = total_loss / num_batches
    metrics["accuracy"] = 0.0  # TODO: Implement accuracy calculation

    return avg_loss, metrics
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    # TensorFlow implementation
    result = model.evaluate(dataloader, verbose=0)
    return result, {}
    {%- endif %}


def _save_checkpoint(model, optimizer, epoch: int, val_loss: float, path: Path) -> None:
    """Save model checkpoint."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch

    checkpoint = {
        "epoch": epoch,
        "model_state_dict": model.state_dict(),
        "optimizer_state_dict": optimizer.state_dict(),
        "val_loss": val_loss,
    }
    torch.save(checkpoint, path)
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    model.save(str(path))
    {%- endif %}


def main():
    """CLI entry point for training."""
    import argparse
    import sys

    parser = argparse.ArgumentParser(description="Train a model")
    parser.add_argument("--config", "-c", type=str, required=True, help="Path to config YAML")
    parser.add_argument("--output-dir", "-o", type=str, default=None, help="Output directory")
    args = parser.parse_args()

    try:
        results = train(args.config, output_dir=args.output_dir)
        print(f"Training completed. Best validation loss: {results.get('best_val_loss', 'N/A')}")
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
