logger = logging.getLogger(__name__)


def train(
    config: ExperimentConfig | str | Path,
    output_dir: str | Path | None = None,
    resume_from: str | Path | None = None,
) -> dict[str, Any]:
    """
    Train a model using the provided configuration.

    Args:
        config: Experiment configuration object or path to YAML config file.
        output_dir: Optional output directory override.
        resume_from: Optional path to checkpoint to resume from.

    Returns:
        Dictionary containing training results and metrics.
    """
    # Load configuration
    if isinstance(config, (str, Path)):
        config = ExperimentConfig.from_yaml(config)

    # Set up output directory
    output_dir = Path(output_dir) if output_dir else Path(config.output_dir) / config.name
    output_dir.mkdir(parents=True, exist_ok=True)

    # Save config
    config.save(output_dir)

    # Initialise tracker
    tracker = _get_tracker(config)

    # Set random seed for reproducibility
    _set_seed(config.training.seed)

    # Prepare data
    train_loader, val_loader = _prepare_data(config)

    # Initialise model
    model = _create_model(config)

    # Initialise optimiser and loss
    optimizer = _create_optimizer(model, config)
    criterion = _create_criterion(config)

    # Learning rate scheduler
    scheduler = _create_scheduler(optimizer, config) if config.training.use_scheduler else None

    # Training loop
    logger.info(f"Starting training for {config.training.num_epochs} epochs")
    logger.info(f"Device: {config.device}")
    logger.info(f"Output directory: {output_dir}")

    best_val_loss = float("inf")
    epochs_without_improvement = 0

    with tracker:
        tracker.start_run(
            run_name=config.name,
            config=config.model_dump(),
        )

        {%- if experiment_tracker == "wandb" %}
        # Watch model gradients (W&B specific)
        tracker.watch_model(model, criterion)  # type: ignore[attr-defined]
        {%- endif %}

        for epoch in range(config.training.num_epochs):
            # Train one epoch
            train_loss = _train_one_epoch(
                model=model,
                dataloader=train_loader,
                optimizer=optimizer,
                criterion=criterion,
                epoch=epoch,
                config=config,
            )

            # Evaluate on validation set
            val_loss, val_metrics = _evaluate_model(
                model=model,
                dataloader=val_loader,
                criterion=criterion,
                config=config,
            )

            # Log metrics
            metrics = {
                "train_loss": train_loss,
                "val_loss": val_loss,
                "epoch": epoch + 1,
                **val_metrics,
            }
            tracker.log_metrics(metrics, step=epoch + 1)

            logger.info(f"Epoch {epoch + 1}/{config.training.num_epochs}: "
                       f"train_loss={train_loss:.4f}, val_loss={val_loss:.4f}")

            # Learning rate scheduling
            if scheduler is not None:
                if config.training.scheduler_type == "reduce_on_plateau":
                    scheduler.step(val_loss)
                else:
                    scheduler.step()

            # Checkpoint best model
            if val_loss < best_val_loss:
                best_val_loss = val_loss
                epochs_without_improvement = 0
                _save_checkpoint(model, optimizer, epoch, val_loss, output_dir / "best_model.pth")
                logger.info(f"Saved new best model with val_loss={val_loss:.4f}")
            else:
                epochs_without_improvement += 1

            # Early stopping
            if epochs_without_improvement >= config.training.early_stopping_patience:
                logger.info(f"Early stopping after {epoch + 1} epochs")
                break

        # Log final model
        tracker.log_model(model, name="final_model")

        # Save training results
        results = {
            "best_val_loss": best_val_loss,
            "final_epoch": epoch + 1,
            "config": config.model_dump(),
        }

        return results


def _get_tracker(config: ExperimentConfig) -> ExperimentTracker:
    """Initialise experiment tracker based on configuration."""
    {%- if experiment_tracker == "wandb" %}
    return ExperimentTracker(
        project=config.project_name,
        name=config.name,
    )
    {%- elif experiment_tracker == "mlflow" %}
    return ExperimentTracker(
        experiment_name=config.name,
    )
    {%- else %}
    return ExperimentTracker()
    {%- endif %}


def _set_seed(seed: int) -> None:
    """Set random seed for reproducibility."""
    import random
    import numpy as np

    random.seed(seed)
    np.random.seed(seed)

    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch
    torch.manual_seed(seed)
    if torch.cuda.is_available():
        torch.cuda.manual_seed_all(seed)
        torch.backends.cudnn.deterministic = True
        torch.backends.cudnn.benchmark = False
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    import tensorflow as tf
    tf.random.set_seed(seed)
    {%- endif %}


