# Default experiment configuration for {{ project_name }}

# Experiment metadata
name: "default_experiment"
description: "Default experiment configuration"
version: "0.1.0"
project_name: "{{ project_name }}"

# Model configuration
model:
  name: "mlp"
  model_type: "mlp"
  input_dim: 784          # e.g., 28x28 flattened images
  output_dim: 10          # e.g., 10 classes
  hidden_dims: [128, 64]  # Hidden layer sizes
  dropout_rate: 0.1
  activation: "relu"

# Training configuration
training:
  # Basic training params
  batch_size: 32
  num_epochs: 10
  num_workers: 4

  # Optimizer
  optimizer:
    name: "adam"
    learning_rate: 0.001
    weight_decay: 0.0001

  # Loss function
  loss:
    name: "cross_entropy"
    reduction: "mean"

  # Learning rate scheduling
  use_scheduler: true
  scheduler_type: "reduce_on_plateau"
  scheduler_patience: 5

  # Regularization
  early_stopping_patience: 10
  gradient_clip_value: 1.0

  # Checkpointing
  save_best_only: true
  checkpoint_dir: "checkpoints"

  # Monitoring
  log_interval: 10
  eval_interval: 1

  # Reproducibility
  seed: 42

# Data paths
train_path: "data/train.csv"
val_path: "data/val.csv"
test_path: "data/test.csv"

# Output paths
output_dir: "outputs"
log_dir: "logs"

# Device configuration
device: "cuda"  # Use "cpu" if no GPU available
use_mixed_precision: false
