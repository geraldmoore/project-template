# Example experiment configuration with hyperparameters for tuning
# Copy this file and modify for your experiments

name: "experiment_001"
description: "Example experiment with custom hyperparameters"
version: "0.1.0"
project_name: "{{ project_name }}"

# Model - larger architecture
model:
  name: "mlp_large"
  model_type: "mlp"
  input_dim: 784
  output_dim: 10
  hidden_dims: [256, 128, 64]  # Deeper network
  dropout_rate: 0.2
  activation: "gelu"

# Training - more aggressive training
training:
  batch_size: 64
  num_epochs: 50
  num_workers: 8

  optimizer:
    name: "adamw"  # AdamW with decoupled weight decay
    learning_rate: 0.0003
    weight_decay: 0.01

  loss:
    name: "cross_entropy"
    reduction: "mean"

  use_scheduler: true
  scheduler_type: "cosine"  # Cosine annealing

  early_stopping_patience: 15
  gradient_clip_value: 0.5

  save_best_only: true
  checkpoint_dir: "checkpoints/experiment_001"

  log_interval: 5
  eval_interval: 1

  seed: 42

# Data
data:
  train_path: "data/train.csv"
  val_path: "data/val.csv"
  test_path: "data/test.csv"
  data_format: "csv"
  target_column: "label"
  normalize: true
  standardize: false
  use_augmentation: false
  shuffle: true
  pin_memory: true
  drop_last: true

# Output
output_dir: "outputs"
log_dir: "logs"

# Device
device: "cuda"
use_mixed_precision: true  # Use mixed precision training
