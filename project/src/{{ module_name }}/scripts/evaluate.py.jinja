def _run_evaluation(model, dataloader, config: ExperimentConfig) -> dict[str, float]:
    """Run evaluation and compute metrics."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch
    import torch.nn as nn

    model.eval()
    device = torch.device(config.device if torch.cuda.is_available() else "cpu")

    total_loss = 0.0
    num_batches = 0
    all_preds = []
    all_targets = []

    criterion = nn.CrossEntropyLoss() if config.model.output_dim > 1 else nn.BCEWithLogitsLoss()

    with torch.no_grad():
        for inputs, targets in dataloader:
            inputs, targets = inputs.to(device), targets.to(device)

            outputs = model(inputs)
            loss = criterion(outputs, targets)

            total_loss += loss.item()
            num_batches += 1

            # Get predictions
            if config.model.output_dim > 1:
                preds = outputs.argmax(dim=1)
            else:
                preds = (torch.sigmoid(outputs) > 0.5).long()

            all_preds.extend(preds.cpu().numpy())
            all_targets.extend(targets.cpu().numpy())

    # Compute metrics
    avg_loss = total_loss / num_batches
    accuracy = sum(p == t for p, t in zip(all_preds, all_targets)) / len(all_targets)

    metrics = {
        "test_loss": avg_loss,
        "accuracy": accuracy,
    }

    # Add classification metrics if applicable
    if config.model.output_dim > 1:
        from sklearn.metrics import precision_score, recall_score, f1_score

        metrics["precision"] = precision_score(all_targets, all_preds, average="weighted", zero_division=0)
        metrics["recall"] = recall_score(all_targets, all_preds, average="weighted", zero_division=0)
        metrics["f1"] = f1_score(all_targets, all_preds, average="weighted", zero_division=0)

    return metrics
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    import numpy as np

    # Evaluate on test data
    result = model.evaluate(dataloader, verbose=0)

    metrics = {
        "test_loss": float(result[0]) if isinstance(result, list) else float(result),
    }

    # Get predictions for additional metrics
    preds = model.predict(dataloader, verbose=0)
    if config.model.output_dim > 1:
        preds = np.argmax(preds, axis=1)

    # TODO: Compute additional metrics based on your needs
    return metrics
    {%- endif %}


def _compute_confusion_matrix(model, dataloader, config: ExperimentConfig) -> list[list[int]]:
    """Compute confusion matrix for classification tasks."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch

    model.eval()
    device = torch.device(config.device if torch.cuda.is_available() else "cpu")

    all_preds = []
    all_targets = []

    with torch.no_grad():
        for inputs, targets in dataloader:
            inputs, targets = inputs.to(device), targets.to(device)
            outputs = model(inputs)
            preds = outputs.argmax(dim=1)
            all_preds.extend(preds.cpu().numpy())
            all_targets.extend(targets.cpu().numpy())

    from sklearn.metrics import confusion_matrix
    cm = confusion_matrix([], [])  # Replace with actual labels
    return cm.tolist()
    {%- endif %}


def main():
    """CLI entry point for evaluation."""
    import argparse
    import sys

    parser = argparse.ArgumentParser(description="Evaluate a model")
    parser.add_argument("--config", "-c", type=str, required=True, help="Path to config YAML")
    parser.add_argument("--model-path", "-m", type=str, required=True, help="Path to model checkpoint")
    parser.add_argument("--output-dir", "-o", type=str, default=None, help="Output directory")
    args = parser.parse_args()

    try:
        metrics = evaluate(args.config, args.model_path, output_dir=args.output_dir)
        for key, value in metrics.items():
            print(f"{key}:{value}")

    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
