"""Weights & Biases experiment tracker."""

from __future__ import annotations

from pathlib import Path
from typing import TYPE_CHECKING, Any

from {{ module_name }}.ml.tracking.base import BaseTracker

if TYPE_CHECKING:
    import wandb


class WandBTracker(BaseTracker):
    """Weights & Biases experiment tracker."""

    def __init__(
        self,
        project: str | None = None,
        entity: str | None = None,
        dir: str | Path | None = None,
        mode: str = "online",
    ):
        self.project = project
        self.entity = entity
        self.dir = Path(dir) if dir else None
        self.mode = mode
        self._run: wandb.Run | None = None

    def start_run(
        self,
        run_name: str | None = None,
        config: dict[str, Any] | None = None,
        tags: list[str] | None = None,
    ) -> None:
        """Start a new W&B run."""
        import wandb

        self._run = wandb.init(
            project=self.project,
            entity=self.entity,
            name=run_name,
            config=config,
            tags=tags,
            dir=self.dir,
            mode=self.mode,
        )

    def log_metrics(self, metrics: dict[str, float], step: int | None = None) -> None:
        """Log metrics to W&B."""
        import wandb

        wandb.log(metrics, step=step)

    def log_params(self, params: dict[str, Any]) -> None:
        """Log parameters to W&B."""
        import wandb

        wandb.config.update(params)

    def log_artifact(self, path: str | Path, name: str | None = None) -> None:
        """Log an artifact to W&B."""
        import wandb

        artifact = wandb.Artifact(name=name or Path(path).name, type="dataset")
        artifact.add_file(str(path))
        wandb.log_artifact(artifact)

    def log_model(self, model: Any, name: str = "model") -> None:
        """Log a model artifact to W&B."""
        import wandb

        artifact = wandb.Artifact(name=name, type="model")

        # Handle PyTorch models
        if hasattr(model, "state_dict"):
            import torch
            path = f"/tmp/{name}.pth"
            torch.save(model.state_dict(), path)
            artifact.add_file(path)
        # Handle TensorFlow/Keras models
        elif hasattr(model, "save"):
            path = f"/tmp/{name}"
            model.save(path)
            artifact.add_dir(path)
        else:
            raise ValueError("Model must be a PyTorch or TensorFlow model")

        wandb.log_artifact(artifact)

    def watch_model(self, model: Any, criterion: Any | None = None, log: str = "gradients", log_freq: int = 100) -> None:
        """Watch model parameters and gradients."""
        import wandb

        wandb.watch(model, criterion=criterion, log=log, log_freq=log_freq)

    def end_run(self) -> None:
        """End the W&B run."""
        import wandb

        if self._run is not None:
            wandb.finish()
            self._run = None
