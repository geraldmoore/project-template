"""MLflow experiment tracker."""

from __future__ import annotations

from pathlib import Path
from typing import TYPE_CHECKING, Any

from {{ module_name }}.ml.tracking.base import BaseTracker

if TYPE_CHECKING:
    import mlflow


class MLFlowTracker(BaseTracker):
    """MLflow experiment tracker."""

    def __init__(
        self,
        tracking_uri: str | None = None,
        experiment_name: str | None = None,
        registry_uri: str | None = None,
    ):
        self.tracking_uri = tracking_uri
        self.experiment_name = experiment_name or "default"
        self.registry_uri = registry_uri
        self._run_id: str | None = None

    def _get_client(self):
        """Get MLflow client."""
        import mlflow
        return mlflow

    def start_run(
        self,
        run_name: str | None = None,
        config: dict[str, Any] | None = None,
        tags: dict[str, str] | None = None,
    ) -> None:
        """Start a new MLflow run."""
        mlflow = self._get_client()

        # Set tracking URI if provided
        if self.tracking_uri:
            mlflow.set_tracking_uri(self.tracking_uri)

        # Set or get experiment
        experiment = mlflow.get_experiment_by_name(self.experiment_name)
        if experiment is None:
            mlflow.create_experiment(self.experiment_name)
        mlflow.set_experiment(self.experiment_name)

        # Start run
        run = mlflow.start_run(run_name=run_name, tags=tags)
        self._run_id = run.info.run_id

        # Log config
        if config:
            self.log_params(config)

    def log_metrics(self, metrics: dict[str, float], step: int | None = None) -> None:
        """Log metrics to MLflow."""
        mlflow = self._get_client()

        if step is not None:
            # Log with step as iteration
            for key, value in metrics.items():
                mlflow.log_metric(key, value, step=step)
        else:
            mlflow.log_metrics(metrics)

    def log_params(self, params: dict[str, Any]) -> None:
        """Log parameters to MLflow."""
        mlflow = self._get_client()

        # Flatten nested dicts for MLflow
        def flatten(d: dict, parent_key: str = "", sep: str = ".") -> dict:
            items = []
            for k, v in d.items():
                new_key = f"{parent_key}{sep}{k}" if parent_key else k
                if isinstance(v, dict):
                    items.extend(flatten(v, new_key, sep=sep).items())
                else:
                    items.append((new_key, v))
            return dict(items)

        flat_params = flatten(params)
        mlflow.log_params(flat_params)

    def log_artifact(self, path: str | Path, name: str | None = None) -> None:
        """Log an artifact to MLflow."""
        mlflow = self._get_client()
        mlflow.log_artifact(str(path), name)

    def log_model(self, model: Any, name: str = "model") -> None:
        """Log a model artifact to MLflow."""
        mlflow = self._get_client()

        # Handle PyTorch models
        if hasattr(model, "state_dict"):
            import torch
            path = f"/tmp/{name}"
            Path(path).mkdir(parents=True, exist_ok=True)
            torch.save(model.state_dict(), f"{path}/model.pth")
            mlflow.pytorch.log_model(model, name)
        # Handle TensorFlow/Keras models
        elif hasattr(model, "save"):
            path = f"/tmp/{name}"
            model.save(path)
            mlflow.tensorflow.log_model(model, name)
        else:
            # Log as generic artifact
            self.log_artifact(str(model), name)

    def register_model(self, model_uri: str, name: str) -> None:
        """Register a model to MLflow Model Registry."""
        mlflow = self._get_client()
        mlflow.register_model(model_uri, name)

    def end_run(self) -> None:
        """End the MLflow run."""
        mlflow = self._get_client()
        if mlflow.active_run():
            mlflow.end_run()
        self._run_id = None
