"""Prediction/inference pipeline for {{ project_name }}."""

from __future__ import annotations

import logging
from pathlib import Path
from typing import Any

import numpy as np

from {{ module_name }}.ml.configs.experiment import ExperimentConfig

logger = logging.getLogger(__name__)


def predict(
    config: ExperimentConfig | str | Path,
    model_path: str | Path,
    inputs: np.ndarray | list | str | Path,
    return_probabilities: bool = False,
) -> dict[str, Any]:
    """
    Run inference using a trained model.

    Args:
        config: Experiment configuration object or path to YAML config file.
        model_path: Path to trained model checkpoint.
        inputs: Input data for prediction. Can be:
            - numpy array of input features
            - list of input features
            - path to a file containing input data
            - path to a directory containing input files
        return_probabilities: Whether to return probabilities (classification) or just predictions.

    Returns:
        Dictionary containing:
            - predictions: Model predictions
            - probabilities: Class probabilities (if return_probabilities=True and classification)
            - preprocessed_inputs: Preprocessed input data
    """
    # Load configuration
    if isinstance(config, (str, Path)):
        config = ExperimentConfig.from_yaml(config)

    # Load model
    model = _load_model(model_path, config)

    # Load and preprocess inputs
    input_data = _load_inputs(inputs, config)
    preprocessed = _preprocess_inputs(input_data, config)

    # Run inference
    predictions, probabilities = _run_inference(model, preprocessed, config, return_probabilities)

    return {
        "predictions": predictions,
        "probabilities": probabilities,
        "preprocessed_inputs": preprocessed,
    }


def predict_batch(
    config: ExperimentConfig | str | Path,
    model_path: str | Path,
    input_dir: str | Path,
    output_path: str | Path,
    batch_size: int = 32,
) -> None:
    """
    Run batch inference on all files in a directory.

    Args:
        config: Experiment configuration object or path to YAML config file.
        model_path: Path to trained model checkpoint.
        input_dir: Directory containing input files.
        output_path: Path to save predictions (JSON or CSV).
        batch_size: Batch size for inference.
    """
    # Load configuration
    if isinstance(config, (str, Path)):
        config = ExperimentConfig.from_yaml(config)

    # Load model
    model = _load_model(model_path, config)

    # Get all input files
    input_files = list(Path(input_dir).glob("*"))
    logger.info(f"Found {len(input_files)} files to process")

    all_results = []

    for i in range(0, len(input_files), batch_size):
        batch_files = input_files[i : i + batch_size]
        batch_results = []

        for file_path in batch_files:
            result = predict(config, model_path, file_path)
            batch_results.append({
                "file": str(file_path),
                "predictions": result["predictions"].tolist()
                if hasattr(result["predictions"], "tolist")
                else result["predictions"],
            })

        all_results.extend(batch_results)
        logger.info(f"Processed {min(i + batch_size, len(input_files))}/{len(input_files)} files")

    # Save results
    output_path = Path(output_path)
    output_path.parent.mkdir(parents=True, exist_ok=True)

    import json

    with open(output_path, "w") as f:
        json.dump(all_results, f, indent=2)

    logger.info(f"Saved predictions to {output_path}")


def _load_model(model_path: str | Path, config: ExperimentConfig):
    """Load trained model from checkpoint."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch

    model = _create_model(config)
    checkpoint = torch.load(model_path, map_location=config.device, weights_only=True)

    if isinstance(checkpoint, dict) and "model_state_dict" in checkpoint:
        model.load_state_dict(checkpoint["model_state_dict"])
    else:
        model.load_state_dict(checkpoint)

    model.eval()
    return model
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    import tensorflow as tf

    return tf.keras.models.load_model(model_path)
    {%- endif %}


def _create_model(config: ExperimentConfig):
    """Create model based on configuration."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch.nn as nn

    class MLP(nn.Module):
        def __init__(self, input_dim: int, hidden_dims: list[int], output_dim: int):
            super().__init__()
            layers = []
            prev_dim = input_dim
            for hidden_dim in hidden_dims:
                layers.extend([
                    nn.Linear(prev_dim, hidden_dim),
                    nn.ReLU(),
                    nn.Dropout(config.model.dropout_rate),
                ])
                prev_dim = hidden_dim
            layers.append(nn.Linear(prev_dim, output_dim))
            self.network = nn.Sequential(*layers)

        def forward(self, x):
            return self.network(x)

    return MLP(
        input_dim=config.model.input_dim,
        hidden_dims=config.model.hidden_dims,
        output_dim=config.model.output_dim,
    )
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    import tensorflow as tf

    model = tf.keras.Sequential([
        tf.keras.layers.Input(shape=(config.model.input_dim,)),
        *[tf.keras.layers.Dense(dim, activation="relu") for dim in config.model.hidden_dims],
        tf.keras.layers.Dropout(config.model.dropout_rate),
        tf.keras.layers.Dense(config.model.output_dim, activation="softmax" if config.model.output_dim > 1 else "sigmoid"),
    ])
    return model
    {%- endif %}


def _load_inputs(inputs: np.ndarray | list | str | Path, config: ExperimentConfig) -> np.ndarray:
    """Load inputs from various sources."""
    if isinstance(inputs, np.ndarray):
        return inputs
    elif isinstance(inputs, list):
        return np.array(inputs)
    elif isinstance(inputs, (str, Path)):
        path = Path(inputs)
        if path.is_file():
            # Load from file (CSV, NPY, etc.)
            if path.suffix == ".npy":
                return np.load(path)
            elif path.suffix == ".csv":
                import pandas as pd

                return pd.read_csv(path).values
            elif path.suffix in [".json", ".jsonl"]:
                import json

                with open(path) as f:
                    data = json.load(f)
                return np.array(data)
            else:
                raise ValueError(f"Unsupported file format: {path.suffix}")
        elif path.is_dir():
            # Load all files in directory
            files = list(path.glob("*"))
            return np.array([_load_file(f) for f in files])
        else:
            raise ValueError(f"Path does not exist: {path}")
    else:
        raise ValueError(f"Unsupported input type: {type(inputs)}")


def _load_file(path: Path) -> np.ndarray:
    """Load a single file."""
    if path.suffix == ".npy":
        return np.load(path)
    elif path.suffix == ".csv":
        import pandas as pd

        return pd.read_csv(path).values
    else:
        raise ValueError(f"Unsupported file format: {path.suffix}")


def _preprocess_inputs(inputs: np.ndarray, config: ExperimentConfig) -> np.ndarray:
    """Preprocess inputs for model."""
    # Normalize if configured
    if config.data.normalize:
        inputs = inputs.astype(np.float32) / 255.0

    # Standardize if configured
    if config.data.standardize:
        mean = inputs.mean(axis=0, keepdims=True)
        std = inputs.std(axis=0, keepdims=True) + 1e-8
        inputs = (inputs - mean) / std

    # Ensure correct dtype
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    # PyTorch expects float32
    inputs = inputs.astype(np.float32)
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    # TensorFlow can handle various dtypes but float32 is standard
    inputs = inputs.astype(np.float32)
    {%- endif %}

    return inputs


def _run_inference(model, inputs: np.ndarray, config: ExperimentConfig, return_probabilities: bool) -> tuple:
    """Run inference and return predictions."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    import torch

    model.eval()
    device = torch.device(config.device if torch.cuda.is_available() else "cpu")

    with torch.no_grad():
        # Convert to tensor
        input_tensor = torch.from_numpy(inputs).to(device)

        # Handle different input shapes
        if input_tensor.dim() == 1:
            input_tensor = input_tensor.unsqueeze(0)
        elif input_tensor.dim() > 2:
            # Reshape to (batch, features)
            batch_size = input_tensor.shape[0]
            input_tensor = input_tensor.view(batch_size, -1)

        # Forward pass
        outputs = model(input_tensor)

        # Get predictions
        if config.model.output_dim > 1:
            # Classification
            probabilities = torch.softmax(outputs, dim=-1)
            predictions = torch.argmax(probabilities, dim=-1)
        else:
            # Regression or binary classification
            probabilities = torch.sigmoid(outputs) if return_probabilities else None
            predictions = outputs

        return predictions.cpu().numpy(), probabilities.cpu().numpy() if probabilities is not None else None
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    # Handle different input shapes
    if inputs.ndim == 1:
        inputs = np.expand_dims(inputs, axis=0)

    # Forward pass
    outputs = model.predict(inputs, verbose=0)

    # Get predictions
    if config.model.output_dim > 1:
        # Classification
        if return_probabilities:
            probabilities = outputs
        predictions = np.argmax(outputs, axis=-1)
    else:
        # Regression or binary classification
        predictions = outputs
        probabilities = outputs if return_probabilities else None

    return predictions, probabilities
    {%- endif %}
