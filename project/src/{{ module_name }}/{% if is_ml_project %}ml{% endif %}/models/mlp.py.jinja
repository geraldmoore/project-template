"""Multi-Layer Perceptron (MLP) model implementation."""

from __future__ import annotations

from pathlib import Path
from typing import Any

from {{ module_name }}.ml.configs.model import ModelConfig
from {{ module_name }}.ml.models.base import BaseModel


class MLP(BaseModel):
    """
    Multi-Layer Perceptron for classification or regression.

    A simple fully connected neural network with configurable hidden layers,
    dropout, and activation functions.
    """

    def __init__(
        self,
        input_dim: int,
        output_dim: int,
        hidden_dims: list[int] | None = None,
        dropout_rate: float = 0.1,
        activation: str = "relu",
    ):
        """
        Initialize MLP.

        Args:
            input_dim: Dimension of input features
            output_dim: Dimension of output (num classes for classification)
            hidden_dims: List of hidden layer dimensions
            dropout_rate: Dropout probability
            activation: Activation function name
        """
        super().__init__()

        {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
        import torch.nn as nn

        self.input_dim = input_dim
        self.output_dim = output_dim
        self.hidden_dims = hidden_dims or [128, 64]
        self.dropout_rate = dropout_rate
        self.activation_name = activation

        # Build layers
        layers = []
        prev_dim = input_dim

        for hidden_dim in self.hidden_dims:
            layers.extend([
                nn.Linear(prev_dim, hidden_dim),
                self._get_activation(activation),
                nn.Dropout(dropout_rate),
            ])
            prev_dim = hidden_dim

        # Output layer
        layers.append(nn.Linear(prev_dim, output_dim))

        self.network = nn.Sequential(*layers)
        {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
        import tensorflow as tf

        self.input_dim = input_dim
        self.output_dim = output_dim
        self.hidden_dims = hidden_dims or [128, 64]
        self.dropout_rate = dropout_rate

        # Build model
        inputs = tf.keras.Input(shape=(input_dim,))
        x = inputs

        for hidden_dim in self.hidden_dims:
            x = tf.keras.layers.Dense(hidden_dim, activation=activation)(x)
            x = tf.keras.layers.Dropout(dropout_rate)(x)

        # Output layer
        if output_dim > 1:
            # Multi-class classification
            outputs = tf.keras.layers.Dense(output_dim, activation="softmax")(x)
        else:
            # Binary classification or regression
            outputs = tf.keras.layers.Dense(1, activation="sigmoid")(x)

        self.network = tf.keras.Model(inputs=inputs, outputs=outputs)
        {%- endif %}

    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    def _get_activation(self, name: str):
        """Get activation function by name."""
        import torch.nn as nn

        activations = {
            "relu": nn.ReLU(),
            "gelu": nn.GELU(),
            "sigmoid": nn.Sigmoid(),
            "tanh": nn.Tanh(),
            "leaky_relu": nn.LeakyReLU(0.01),
        }
        return activations.get(name, nn.ReLU())

    def forward(self, x):
        """Forward pass."""
        return self.network(x)

    def save(self, path: str | Path) -> None:
        """Save model state dict."""
        import torch

        path = Path(path)
        path.parent.mkdir(parents=True, exist_ok=True)
        torch.save(self.state_dict(), path)

    @classmethod
    def load(cls, path: str | Path, config: ModelConfig) -> "MLP":
        """Load model from state dict."""
        import torch

        model = cls(
            input_dim=config.input_dim,
            output_dim=config.output_dim,
            hidden_dims=config.hidden_dims,
            dropout_rate=config.dropout_rate,
            activation=config.activation,
        )
        model.load_state_dict(torch.load(path, map_location="cpu", weights_only=True))
        return model

    def get_config(self) -> dict[str, Any]:
        """Get model configuration."""
        return {
            "model_type": "mlp",
            "input_dim": self.input_dim,
            "output_dim": self.output_dim,
            "hidden_dims": self.hidden_dims,
            "dropout_rate": self.dropout_rate,
            "activation": self.activation_name,
        }
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    def call(self, inputs, training=False):
        """Forward pass."""
        return self.network(inputs, training=training)

    def save(self, path: str | Path) -> None:
        """Save model."""
        path = Path(path)
        path.parent.mkdir(parents=True, exist_ok=True)
        self.network.save(str(path))

    @classmethod
    def load(cls, path: str | Path, config: ModelConfig | None = None) -> "MLP":
        """Load model."""
        import tensorflow as tf

        model_wrapper = cls(
            input_dim=config.input_dim if config else 784,
            output_dim=config.output_dim if config else 10,
            hidden_dims=config.hidden_dims if config else [128, 64],
            dropout_rate=config.dropout_rate if config else 0.1,
            activation=config.activation if config else "relu",
        )
        model_wrapper.network = tf.keras.models.load_model(str(path))
        return model_wrapper

    def get_config(self) -> dict[str, Any]:
        """Get model configuration."""
        return {
            "model_type": "mlp",
            "input_dim": self.input_dim,
            "output_dim": self.output_dim,
            "hidden_dims": self.hidden_dims,
            "dropout_rate": self.dropout_rate,
        }
    {%- endif %}
