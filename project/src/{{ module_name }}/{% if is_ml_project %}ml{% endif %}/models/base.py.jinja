"""Base model class."""

from abc import ABC, abstractmethod
from pathlib import Path
from typing import Any


class BaseModel(ABC):
    """Abstract base class for all models."""

    @abstractmethod
    def forward(self, *args, **kwargs):
        """Forward pass through the model."""
        pass

    @abstractmethod
    def save(self, path: str | Path) -> None:
        """Save model to disk."""
        pass

    @classmethod
    @abstractmethod
    def load(cls, path: str | Path, **kwargs) -> Any:
        """Load model from disk."""
        pass

    @abstractmethod
    def get_config(self) -> dict[str, Any]:
        """Get model configuration as dictionary."""
        pass

    def count_parameters(self) -> int:
        """Count trainable parameters."""
        {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
        return sum(p.numel() for p in self.parameters() if p.requires_grad)
        {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
        return sum(var.shape.num_elements() for var in self.trainable_variables)
        {%- endif %}
