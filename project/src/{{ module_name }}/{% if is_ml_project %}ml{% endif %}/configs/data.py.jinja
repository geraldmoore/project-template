"""Data configuration schema."""

from typing import Any

from pydantic import BaseModel, Field


class DataConfig(BaseModel):
    """Data loading and preprocessing configuration."""

    # Data paths
    train_path: str = Field(default="data/train", description="Training data path")
    val_path: str = Field(default="data/val", description="Validation data path")
    test_path: str = Field(default="data/test", description="Test data path")

    # Data format
    data_format: str = Field(default="csv", description="Data format (csv, json, parquet, etc.)")
    target_column: str = Field(default="target", description="Target column name")

    # Preprocessing
    normalize: bool = Field(default=True, description="Normalize input features")
    standardize: bool = Field(default=False, description="Standardize input features")

    # Augmentation
    use_augmentation: bool = Field(default=False, description="Use data augmentation")
    augmentation_params: dict[str, Any] = Field(default_factory=dict, description="Augmentation parameters")

    # Train/val/test split
    train_split: float = Field(default=0.8, gt=0.0, le=1.0, description="Training split ratio")
    val_split: float = Field(default=0.1, gt=0.0, le=1.0, description="Validation split ratio")
    test_split: float = Field(default=0.1, gt=0.0, le=1.0, description="Test split ratio")

    # Loading options
    shuffle: bool = Field(default=True, description="Shuffle training data")
    pin_memory: bool = Field(default=True, description="Pin memory for data loading")
    drop_last: bool = Field(default=False, description="Drop last incomplete batch")

    class Config:
        extra = "allow"
