def _load_dataset(path: str, config: DataConfig):
    """Load dataset from path."""
    {%- if ml_framework == "pytorch" or ml_framework == "agnostic" %}
    from torch.utils.data import Dataset
    import pandas as pd

    class CustomDataset(Dataset):
        def __init__(self, data_path: str, data_config: DataConfig):
            self.data = pd.read_csv(data_path) if data_path.endswith('.csv') else pd.read_parquet(data_path)
            self.target_column = data_config.target_column

        def __len__(self):
            return len(self.data)

        def __getitem__(self, idx):
            row = self.data.iloc[idx]
            features = row.drop(self.target_column).values
            target = row[self.target_column]
            return features.astype('float32'), target

    return CustomDataset(path, config)
    {%- elif ml_framework == "tensorflow" or ml_framework == "agnostic" %}
    import tensorflow as tf
    import pandas as pd

    def _parse_csv(filename):
        df = pd.read_csv(filename)
        features = df.drop(columns=[config.target_column]).values.astype('float32')
        labels = df[config.target_column].values
        return tf.data.Dataset.from_tensor_slices((features, labels))

    return _parse_csv(path)
    {%- endif %}


