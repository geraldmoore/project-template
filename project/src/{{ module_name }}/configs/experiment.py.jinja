"""Experiment configuration schema."""

from pathlib import Path

import yaml
from pydantic import BaseModel, Field

from {{ module_name }}.configs.model import ModelConfig
from {{ module_name }}.configs.training import TrainingConfig


class ExperimentConfig(BaseModel):
    """Root experiment configuration."""

    # Experiment metadata
    name: str = Field(default="experiment", description="Experiment name")
    description: str = Field(default="", description="Experiment description")
    version: str = Field(default="0.1.0", description="Experiment version")

    # Project identifier
    project_name: str = Field(default="{{ project_name }}", description="Project name")

    # Sub-configurations
    model: ModelConfig = Field(default_factory=ModelConfig)
    training: TrainingConfig = Field(default_factory=TrainingConfig)

    # Data paths
    train_path: str = Field(default="data/train", description="Training data path")
    val_path: str = Field(default="data/val", description="Validation data path")
    test_path: str = Field(default="data/test", description="Test data path")

    # Output paths
    output_dir: str = Field(default="outputs", description="Output directory")
    log_dir: str = Field(default="logs", description="Log directory")

    # Device configuration
    device: str = Field(default="cuda", description="Device to use (cuda, cpu, mps)")
    use_mixed_precision: bool = Field(default=False, description="Use mixed precision training")

    @classmethod
    def from_yaml(cls, path: str | Path) -> "ExperimentConfig":
        """Load experiment configuration from YAML file."""
        with open(path) as f:
            config_dict = yaml.safe_load(f)
        return cls(**config_dict)

    def to_yaml(self, path: str | Path) -> None:
        """Save experiment configuration to YAML file."""
        with open(path, "w") as f:
            yaml.dump(self.model_dump(), f, default_flow_style=False, sort_keys=False)

    def save(self, output_dir: str | Path) -> None:
        """Save configuration to output directory."""
        output_path = Path(output_dir)
        output_path.mkdir(parents=True, exist_ok=True)
        self.to_yaml(output_path / "config.yaml")
